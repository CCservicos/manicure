rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // App atual não usa Firestore — tudo bloqueado.
    // Quando criar coleções, substitua por regras específicas (ex.: match /users/{uid} { ... }).
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
