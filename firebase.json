{
  "firestore": {
    "rules": "firestore.rules"
  },
  "database": {
    "rules": "database.rules.json"
  },
  "hosting": {
    "public": ".",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "rewrites": [
      { "source": "/agendar", "destination": "/index.html" },
      { "source": "/cliente/**", "destination": "/index.html" }
    ]
  }
}
